# ─────────────────────────────────────────────
# MintKit — Environment Variables
# Copy this file to .env and fill in your keys
# NEVER commit .env to GitHub
# ─────────────────────────────────────────────

# ── Anthropic ─────────────────────────────────
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Twitter / X ───────────────────────────────
# Get from: developer.twitter.com → Your App → Keys and Tokens
# Bearer Token = used for scanning (read only)
TWITTER_BEARER_TOKEN=your-bearer-token-here

# Consumer Key + Secret = your app credentials
TWITTER_API_KEY=your-consumer-key-here
TWITTER_API_SECRET=your-consumer-secret-here

# Access Token + Secret = your account credentials (needs Read+Write)
TWITTER_ACCESS_TOKEN=your-access-token-here
TWITTER_ACCESS_SECRET=your-access-token-secret-here

# ── Solana ────────────────────────────────────
# Path to your deployer wallet JSON file
WALLET_PATH=./deployer_wallet.json

# Network: devnet for testing, mainnet for real launches
NETWORK=devnet
